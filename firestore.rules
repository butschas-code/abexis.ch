rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * Public read: published blog posts (anonymous Web SDK / SSR fallback without Admin SDK).
     * Writes remain authenticated only.
     */
    match /posts/{postId} {
      allow read: if resource.data.status == "published";
      allow write: if request.auth != null;
    }

    match /vacancies/{vacancyId} {
      allow read: if resource.data.status == "published";
      allow write: if request.auth != null;
    }

    /** Category labels for filters / UI — no secrets; public read. */
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /** Everything else (authors, users, submissions, media, settings, …). */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
